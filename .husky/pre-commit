#!/bin/sh

echo "Running TypeScript type check (frontend)..."
cd frontend && npx tsc -b --noEmit
if [ $? -ne 0 ]; then
  echo "Frontend TypeScript check failed. Fix errors before committing."
  exit 1
fi

echo "Running TypeScript type check (backend)..."
cd ../backend && npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "Backend TypeScript check failed. Fix errors before committing."
  exit 1
fi

echo "Type checks passed."
